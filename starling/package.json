{
  "name": "@zhuo-andy_bcgprod/starling",
  "version": "0.1.2",
  "private": false,
  "description": "Dev-only in-browser annotation tool for React prototypes. Mark up components, compile feedback into one Markdown+JSON artifact for Claude.",
  "keywords": [
    "react",
    "annotation",
    "dev-tool",
    "prototype",
    "feedback",
    "claude"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zhuo-Andy_bcgprod/starling.git"
  },
  "homepage": "https://github.com/Zhuo-Andy_bcgprod/starling#readme",
  "bugs": {
    "url": "https://github.com/Zhuo-Andy_bcgprod/starling/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/Starling.d.ts",
      "default": "./dist/react/Starling.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "default": "./dist/next/index.js"
    },
    "./next/config": {
      "types": "./dist/plugin/next.d.ts",
      "default": "./dist/plugin/next.js"
    },
    "./plugin/vite": {
      "types": "./dist/plugin/vite.d.ts",
      "default": "./dist/plugin/vite.js"
    },
    "./plugin/snapshots": {
      "types": "./dist/plugin/snapshots.d.ts",
      "default": "./dist/plugin/snapshots.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@babel/types": "^7.24.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.9.2",
    "@types/react": "^19",
    "jsdom": "^25.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
