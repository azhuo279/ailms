# GitHub Packages registry routing for the Starling package scope.
#
# IMPORTANT: replace `@starling` below with the REAL scope once chosen — it MUST
# exactly match the GitHub org/user that owns the package (the "emu" account).
# The same scope must appear in package.json "name" (@<scope>/starling).
#
# The auth token is read from the environment (never commit a real token):
#   - CI:    NODE_AUTH_TOKEN is set by actions/setup-node.
#   - Local: `export NODE_AUTH_TOKEN=<a PAT with write:packages (+ repo if private)>`
@zhuo-andy_bcgprod:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
